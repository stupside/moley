---
import SearchEngines from "../components/layout/SearchEngines.astro";
import { config } from "../config.js";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>
  <SearchEngines
    slot="head"
    image={config.site.logo}
    title="Page Not Found - Moley"
    description="The page you're looking for doesn't exist."
  />

  <section class="pt-32 pb-24 min-h-screen">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <span class="font-mono text-8xl font-black text-neutral-700/50">404</span>
      <h1 class="text-2xl font-bold text-neutral-100 mt-6">Page not found</h1>
      <p class="text-neutral-400 mt-2">This page doesn't exist or has been moved.</p>
      <a
        href={`${import.meta.env.BASE_URL}`}
        class="inline-block mt-6 text-sm text-orange-500 hover:text-neutral-100 transition-colors font-mono"
      >
        cd ~
      </a>
    </div>
  </section>
</BaseLayout>
