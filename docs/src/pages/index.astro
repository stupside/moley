---
import Hero from "../components/features/Hero.astro";
import SearchEngines from "../components/layout/SearchEngines.astro";
import { layoutClasses } from "../components/layout/shared.js";
import { config } from "../config.js";
import BaseLayout from "../layouts/BaseLayout.astro";

const heroData = {
	title: "Turn localhost into ",
	titleAccent: "production URLs.",
	subtitle:
		"Cloudflare Tunnels are free and powerful but painful to configure. Moley handles tunnel creation, DNS routing, and cleanup so you don't have to.",
	logo: {
		src: config.site.logo,
		alt: "Moley",
		width: 160,
		height: 160,
	},
};

const title = "Moley – Automated Cloudflare Tunnels for Custom Domains";
const description =
	"Cloudflare Tunnel automation for developers. Turn localhost into production URLs with one command. Automated config, DNS routing, and cleanup.";
---

<BaseLayout>
  <SearchEngines
    slot="head"
    image={config.site.logo}
    title={title}
    description={description}
    type="website"
  />

  <Hero {...heroData} />

  <section class="border-t border-neutral-800 py-24">
    <div class={layoutClasses.container}>
      <h2 class="text-3xl font-black text-neutral-100 tracking-tight">
        Without Moley
      </h2>
      <div class="mt-8 mb-20 space-y-1 font-mono text-sm text-neutral-400">
        <div><span class="text-neutral-600">1</span>  Authenticate with Cloudflare</div>
        <div><span class="text-neutral-600">2</span>  Create tunnel manually</div>
        <div><span class="text-neutral-600">3</span>  Write YAML config with ingress rules</div>
        <div><span class="text-neutral-600">4</span>  Route DNS for each subdomain</div>
        <div><span class="text-neutral-600">5</span>  Run the tunnel</div>
        <div><span class="text-neutral-600">6</span>  Manually delete tunnel + DNS records when done</div>
      </div>

      <h2 class="text-3xl font-black text-orange-500 tracking-tight">
        With Moley
      </h2>
      <div class="mt-8 font-mono text-sm">
        <span class="text-neutral-500">$</span> <span class="text-orange-500">moley tunnel run</span>
      </div>
      <p class="mt-6 text-neutral-300 text-sm max-w-md">
        Creates the tunnel, generates config, sets up DNS, runs it, and cleans up when you stop. That's it.
      </p>
    </div>
  </section>

</BaseLayout>
