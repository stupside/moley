---
import type { PageDefinition } from "../../types/content.js";
import { extractTocItems } from "../../utils/content.js";

export interface Props {
	page: PageDefinition;
}

const { page } = Astro.props;
const items = extractTocItems(page.content);
---

{
  items.length > 0 && (
    <nav class="sticky top-24 max-h-[calc(100vh-8rem)] overflow-y-auto w-44 hidden lg:block">
      <div class="font-mono text-[10px] uppercase tracking-[0.15em] text-neutral-600 mb-4">On this page</div>
      <div class="flex flex-col">
        {items.filter(item => item.level === 2 && item.id && item.title).map((item) => (
          <a
            href={`#${item.id}`}
            class="py-1 text-[13px] text-neutral-600 hover:text-neutral-100 transition-colors"
            data-toc-link={item.id}
          >
            {item.title}
          </a>
        ))}

        {items.filter(item => item.level === 3 && item.id && item.title).map((item) => (
          <a
            href={`#${item.id}`}
            class="py-0.5 pl-3 text-xs text-neutral-700 hover:text-neutral-100 transition-colors"
            data-toc-link={item.id}
          >
            {item.title}
          </a>
        ))}
      </div>
    </nav>
  )
}

<script is:inline define:vars={{ tocItems: items }}>
  const SCROLL_OFFSET = 100;

  const findActiveHeading = () => {
    const scrollY = window.scrollY + SCROLL_OFFSET;
    let lastActive = null;

    for (const item of tocItems) {
      const element = document.getElementById(item.id);
      if (element && element.offsetTop <= scrollY) {
        lastActive = item.id;
      }
    }
    return lastActive;
  };

  const updateActiveLink = () => {
    const links = document.querySelectorAll("[data-toc-link]");
    const activeId = findActiveHeading();

    links.forEach((link) => {
      const id = link.getAttribute("data-toc-link");
      const isActive = id === activeId;
      const item = tocItems.find(i => i.id === id);
      const isH3 = item && item.level === 3;

      if (isActive) {
        link.className = isH3
          ? "py-0.5 pl-3 text-xs text-orange-500 transition-colors"
          : "py-1 text-[13px] text-orange-500 transition-colors";
      } else {
        link.className = isH3
          ? "py-0.5 pl-3 text-xs text-neutral-700 hover:text-neutral-100 transition-colors"
          : "py-1 text-[13px] text-neutral-600 hover:text-neutral-100 transition-colors";
      }
    });
  };

  document.addEventListener("scroll", updateActiveLink);
  document.addEventListener("DOMContentLoaded", updateActiveLink);
</script>
