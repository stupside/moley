---
import { config } from "../../config.js";
import { layoutClasses } from "./shared.js";
import Icon from "../ui/Icon/Icon.astro";
import Navigation from "./Navigation.astro";

export interface Props {
	currentPath: string;
}

const { currentPath } = Astro.props;
const items = config.navigation.items;
---

<header class="sticky top-0 z-50 w-full bg-neutral-950/90 backdrop-blur-sm">
  <div class={layoutClasses.container}>
    <div class="flex h-14 items-center justify-between border-b border-neutral-800">
      <a href={`${import.meta.env.BASE_URL}`} class="font-mono text-sm text-neutral-100 hover:text-orange-500 transition-colors">
        {config.site.name}
      </a>

      <div class="flex items-center gap-4">
        <Navigation items={items} currentPath={currentPath} />
        <a
          href={config.site.repo.url}
          target="_blank"
          rel="noopener noreferrer nofollow"
          class="text-neutral-600 hover:text-neutral-100 transition-colors"
        >
          <Icon name="github" size="sm" />
        </a>
      </div>
    </div>
  </div>
</header>
