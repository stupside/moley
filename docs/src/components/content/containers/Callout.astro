---
import type { CalloutBlock } from "../../../types/content.js";
import { mergeClassName } from "../../../utils/classes.js";
import { containerStyles } from "./shared.js";
import ContentRenderer from "../../ContentRenderer.astro";

export interface Props {
	content: CalloutBlock;
}

const { content } = Astro.props;
const style =
	content.style && content.style in containerStyles ? content.style : "note";
---

<div class={mergeClassName(`${containerStyles[style]} border-l-2 border-t-0 border-r-0 border-b-0 pl-5 py-4`, content.className)} id={content.id}>
  <div class="flex flex-col gap-3">
    {content.children?.map(child => (
      <ContentRenderer content={child} />
    ))}
  </div>
</div>
