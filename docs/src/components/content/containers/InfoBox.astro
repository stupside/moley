---
import type { InfoBoxBlock } from "../../../types/content.js";
import { mergeClassName, cn } from "../../../utils/classes.js";
import { containerStyles, containerTitleStyles } from "./shared.js";
import ContentRenderer from "../../ContentRenderer.astro";

export interface Props {
	content: InfoBoxBlock;
}

const { content } = Astro.props;
const style =
	content.style && content.style in containerStyles ? content.style : "info";
---

<div class={mergeClassName(`${containerStyles[style]} border-l-2 border-t-0 border-r-0 border-b-0 pl-5 py-3`, content.className)} id={content.id}>
  <div class="flex flex-col gap-2">
    {content.title && (
      <div class={cn("text-sm font-mono font-medium", containerTitleStyles[style])}>{content.title}</div>
    )}
    {content.children?.map(child => (
      <ContentRenderer content={child} />
    ))}
  </div>
</div>
