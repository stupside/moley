---
import type { StepBlock } from "../../../types/content.js";
import { mergeClassName } from "../../../utils/classes.js";
import ContentRenderer from "../../ContentRenderer.astro";

export interface Props {
	content: StepBlock;
}

const { content } = Astro.props;

const stepNumber = content.number || 1;
const stepId =
	content.id ||
	content.title
		.toLowerCase()
		.replace(/[^\w\s-]/g, "")
		.replace(/\s+/g, "-");
---

<div
  class={mergeClassName("flex gap-6", content.className)}
  id={content.id}
>
  <div class="flex-shrink-0 pt-0.5">
    <span class="font-mono text-3xl font-black text-neutral-700/50">{String(stepNumber).padStart(2, '0')}</span>
  </div>

  <div class="flex flex-col gap-3 pb-8 border-b border-neutral-800 flex-1">
    <div>
      <h3 class="text-base font-semibold text-neutral-100" id={stepId}>
        {content.title}
      </h3>
      {
        content.description && (
          <p class="text-neutral-400 text-sm mt-1">{content.description}</p>
        )
      }
    </div>

    {
      content.children && content.children.length > 0 && (
        <div class="flex flex-col gap-3">
          {content.children.map((child) => (
            <ContentRenderer content={child} />
          ))}
        </div>
      )
    }
  </div>
</div>
