---
import type { CardBlock } from "../../../types/content.js";
import { mergeClassName } from "../../../utils/classes.js";
import { buildUrl } from "../../../utils/content.js";
import Icon from "../../ui/Icon/Icon.astro";

export interface Props {
	content: CardBlock;
}

const { content } = Astro.props;

const linkProps = content.external
	? { target: "_blank", rel: "noopener noreferrer" }
	: {};
---

<div class={mergeClassName("h-full group", content.className)} id={content.id}>
  <a href={buildUrl(content.href)} {...linkProps} class="flex h-full gap-4 py-4 border-b border-neutral-800 hover:border-orange-500/40 transition-colors">
    {content.icon && (
      <div class="flex-shrink-0 text-neutral-600 group-hover:text-orange-500 transition-colors">
        <Icon name={content.icon} size="md" />
      </div>
    )}

    <div class="flex-1 min-w-0">
      <div class="text-sm text-neutral-100 group-hover:text-orange-500 transition-colors flex items-center gap-2">
        {content.title}
        {content.external && (
          <Icon name="link" size="xs" class="text-neutral-700" />
        )}
      </div>
      {content.description && (
        <p class="text-neutral-400 text-sm mt-0.5">{content.description}</p>
      )}
    </div>

    <div class="flex-shrink-0 flex items-center text-neutral-800 group-hover:text-orange-500 transition-colors">
      <Icon name="chevron-right" size="sm" />
    </div>
  </a>
</div>
