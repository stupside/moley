---
import type { InlineCodeBlock } from "../../../types/content.js";
import { mergeClassName } from "../../../utils/classes.js";

export interface Props {
	content: InlineCodeBlock;
}

const { content } = Astro.props;
---

<code
  class={mergeClassName("inline-block mx-0.5 px-1.5 py-0.5 bg-neutral-800/80 text-orange-400 rounded-sm text-sm font-mono border border-neutral-700/40 leading-none align-baseline", content.className)}
  id={content.id}
>
  {content.code}
</code>
