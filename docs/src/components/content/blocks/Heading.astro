---
import type { HeadingBlock } from "../../../types/content.js";
import { mergeClassName } from "../../../utils/classes.js";
import { createSlug } from "../../../utils/content.js";

export interface Props {
	content: HeadingBlock;
}

const { content } = Astro.props;

const headingClasses = {
	1: "text-3xl font-bold text-neutral-100 tracking-tight",
	2: "text-2xl font-bold text-neutral-100 tracking-tight",
	3: "text-lg font-semibold text-neutral-200",
	4: "text-base font-semibold text-neutral-200",
	5: "text-sm font-semibold text-neutral-300",
	6: "text-sm font-medium text-neutral-400",
};

const headingId =
	content.id || (content.text ? createSlug(content.text) : undefined);
const headingClass = mergeClassName(
	headingClasses[content.level],
	content.className,
);
---

{content.level === 1 && <h1 class={headingClass} id={headingId}>{content.text}</h1>}
{content.level === 2 && <h2 class={headingClass} id={headingId}>{content.text}</h2>}
{content.level === 3 && <h3 class={headingClass} id={headingId}>{content.text}</h3>}
{content.level === 4 && <h4 class={headingClass} id={headingId}>{content.text}</h4>}
{content.level === 5 && <h5 class={headingClass} id={headingId}>{content.text}</h5>}
{content.level === 6 && <h6 class={headingClass} id={headingId}>{content.text}</h6>}
