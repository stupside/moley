---
import { layoutClasses } from "../layout/shared.js";
import { mergeClassName } from "../../utils/classes.js";

export interface Badge {
	text: string;
}

export interface Logo {
	src: string;
	alt: string;
	width?: number;
	height?: number;
}

export interface Props {
	logo: Logo;
	title: string;
	titleAccent: string;
	subtitle: string;
	badges?: Badge[];
	class?: string;
}

const {
	title,
	titleAccent,
	subtitle,
	logo,
	badges = [],
	class: className = "",
} = Astro.props;
---

<section class={mergeClassName("pt-32 pb-24", className)}>
  <div class={layoutClasses.container}>
    <div class="max-w-2xl">
      <h1 class="text-5xl sm:text-7xl font-black text-neutral-100 tracking-tighter leading-[0.95]">
        {title}<span class="text-orange-500">{titleAccent}</span>
      </h1>

      <p class="mt-8 text-xl text-neutral-400 leading-relaxed max-w-lg">
        {subtitle}
      </p>

      <slot />
    </div>
  </div>
</section>
