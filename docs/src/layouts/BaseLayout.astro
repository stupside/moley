---
import "../app.css";
import { mergeClassName } from "../utils/classes.js";
import Footer from "../components/layout/Footer.astro";
import Header from "../components/layout/Header.astro";

export interface Props {
	class?: string;
}

const { class: className = "" } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-pt-16">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />

    <slot name="head" />

    <style>
      @view-transition {
        navigation: auto;
      }

      ::view-transition-old(root),
      ::view-transition-new(root) {
        animation-duration: 0.2s;
      }
    </style>
  </head>

  <body class={mergeClassName("bg-neutral-950 text-neutral-300 font-sans antialiased", className)}>
    <Header currentPath={Astro.url.pathname} />

    <main class="relative">
      <slot />
    </main>

    <Footer />
  </body>
</html>
