---
import { documentationPages } from "../content/pages.js";
import { layoutClasses } from "../components/layout/shared.js";
import { buildUrl } from "../utils/content.js";
import BaseLayout from "./BaseLayout.astro";

const { title } = Astro.props;
const currentPath = Astro.url.pathname;

const nav = documentationPages
	.filter((page) => !page.meta.internal)
	.reduce(
		(acc, page) => {
			if (!page.meta.category) {
				return acc;
			}

			const href = page.meta.href;
			const title = page.meta.menuTitle || page.meta.title;
			const category = page.meta.category;

			if (!acc[category]) {
				acc[category] = [];
			}

			acc[category].push({
				href,
				title,
				order: page.meta.order ?? 999,
			});

			return acc;
		},
		{} as Record<
			string,
			{
				title: string;
				href: string;
				order: number;
			}[]
		>,
	);

Object.values(nav).forEach((pages) => {
	pages.sort((a, b) => a.order - b.order);
});
---

<BaseLayout>
  <slot name="head" slot="head" />
  <div class="min-h-screen" transition:persist>
    <div class={layoutClasses.container}>
      <div class="flex">
        <aside class="w-52 flex-shrink-0 hidden md:block" transition:persist="sidebar">
          <div class="sticky top-14 pt-10 pb-12 pr-6 border-r border-neutral-800">
            <nav class="flex flex-col gap-10">
              {Object.entries(nav).map(([category, items]) => (
                <div>
                  <div class="font-mono text-[10px] uppercase tracking-[0.15em] text-neutral-600 mb-4">{category}</div>
                  <div class="flex flex-col">
                    {items.map((item) => {
                      const isActive = currentPath === item.href;
                      return (
                        <a
                          href={buildUrl(item.href)}
                          class:list={[
                            "py-1.5 text-[13px] transition-colors border-r -mr-6 pr-6",
                            {
                              "text-orange-500 border-orange-500 font-medium": isActive,
                              "text-neutral-500 hover:text-neutral-100 border-transparent": !isActive,
                            },
                          ]}
                        >
                          {item.title}
                        </a>
                      );
                    })}
                  </div>
                </div>
              ))}
              <slot name="sidebar-actions" />
            </nav>
          </div>
        </aside>

        <div class="flex-1 min-w-0 pt-10 pb-16 md:pl-16">
          <div class="flex gap-16">
            <div class="flex-1 min-w-0 max-w-2xl">
              <header class="mb-12">
                <h1
                  class="text-4xl font-extrabold text-neutral-100 tracking-tight leading-tight"
                  transition:name={`title-${title}`}
                >
                  {title}
                </h1>
                <slot name="header-actions" />
              </header>

              <article class="max-w-none">
                <slot />
              </article>
            </div>

            <slot name="right-sidebar" />
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
